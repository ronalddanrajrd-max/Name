# ═══════════════════════════════════════════
#   OKVEHUB BOT — Variables d'environnement
#   À configurer dans Railway > Variables
# ═══════════════════════════════════════════

# ══════ DISCORD (OBLIGATOIRE) ══════
TOKEN=TON_TOKEN_BOT_ICI
GUILD_ID=ID_DE_TON_SERVEUR

# ══════ ROLES (IDs) ══════
ROLE_OWNER=ID_ROLE_OWNER
ROLE_ADMIN=ID_ROLE_ADMIN
ROLE_MODERATEUR=ID_ROLE_MODERATEUR
ROLE_STAFF=ID_ROLE_STAFF
ROLE_WHITELIST=ID_ROLE_WHITELIST
ROLE_ACHETEUR=ID_ROLE_ACHETEUR
ROLE_UNVERIFIED=ID_ROLE_UNVERIFIED

# ══════ CHANNELS (IDs) ══════
CHANNEL_LOGS=ID_CHANNEL_LOGS
CHANNEL_LOGS_MOD=ID_CHANNEL_LOGS_MOD
CHANNEL_LOGS_WHITELIST=ID_CHANNEL_LOGS_WHITELIST
CHANNEL_ANNONCES=ID_CHANNEL_ANNONCES
CHANNEL_BIENVENUE=ID_CHANNEL_BIENVENUE
CHANNEL_AUREVOIR=ID_CHANNEL_AUREVOIR
CHANNEL_SUGGESTIONS=ID_CHANNEL_SUGGESTIONS
CHANNEL_UPDATES=ID_CHANNEL_UPDATES
CHANNEL_VENTES=ID_CHANNEL_VENTES

# ══════ CATÉGORIES (IDs) ══════
CATEGORY_TICKETS=ID_CATEGORIE_TICKETS

# ══════ RAILWAY ══════
PORT=3000
